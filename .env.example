# ===========================================
# Supabase Configuration (Required)
# ===========================================
# Get these from your Supabase project dashboard: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key for admin operations (password reset, etc.)
# Found in Supabase dashboard: Settings > API > service_role key
# WARNING: Never expose this key on the client side
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# Email Service - SendGrid (Required)
# ===========================================
# Get your API key from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your-sendgrid-api-key

# ===========================================
# Cron Jobs (Optional)
# ===========================================
# Secret token to authorize cron job requests
# Generate a secure random string (e.g., openssl rand -hex 32)
# Used by /api/cron/cleanup-tokens endpoint
CRON_SECRET=your-secure-random-string
